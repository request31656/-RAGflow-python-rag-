# My-RAG 配置。后端能力全交给 ragflow docker。

# ---- ragflow（核心后端：解析/检索/存储）----
# 起服务：cd ragflow-main/ragflow-main/docker && docker compose -p ragflow up -d
# 然后 http://localhost:9380 注册账号、在个人设置里建 API key 填下面。
RAGFLOW_BASE_URL=http://localhost:9380
RAGFLOW_API_KEY=
# 第二阶段对话默认绑定的知识库 id（可空，前端选）
RAGFLOW_DATASET_ID=

# ---- LLM（第二阶段对话生成用；第一阶段数据侧不用）----
BACKEND=simple
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ---- 检索默认参数 ----
TOP_K=10
SIMILARITY_THRESHOLD=0.2
VECTOR_SIMILARITY_WEIGHT=0.3

# ---- Langfuse（tracing，空 key 降级，不影响运行）----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
